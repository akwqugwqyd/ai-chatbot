# Code Review AI Chatbot - Backend Configuration

# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/code-review-db

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production-67890
TOKEN_EXPIRY=7d

# OpenAI API (Official)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# GitHub PR Review Integration
# Token needs repo read access for private PRs and issues:write/pull_requests:read to post comments.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=replace-with-the-secret-you-set-in-github
# Leave async on Vercel so GitHub gets a fast 202 response while review runs in waitUntil.
GITHUB_WEBHOOK_PROCESS_MODE=async
MAX_PR_DIFF_CHARS=50000

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Optional cookie domain. Leave empty for Vercel same-domain deployments.
# Only set this for shared parent domains such as example.com, never include https://.
COOKIE_DOMAIN=

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
DAILY_REVIEW_LIMIT=5

# Optional: Sentry (Error Tracking)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
